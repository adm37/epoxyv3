---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import FAQ from '../components/FAQ';
import Footer from '../components/Footer';
import CTA from '../components/CTA';
---

<BaseLayout title="Veelgestelde Vragen over Epoxy Vloeren | Klasse Epoxy" description="Antwoorden op de meest gestelde vragen over epoxy vloeren: kosten, installatie, onderhoud, droogtijd en het aanvraagproces bij Klasse Epoxy.">
  <div class="min-h-screen selection:bg-epoxy-accent selection:text-epoxy-black">
    <Navbar />
    <main class="pt-20">
      <FAQ />
      <CTA />
    </main>
    <Footer />
  </div>
</BaseLayout>