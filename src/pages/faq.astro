---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import FAQ from '../components/FAQ';
import Footer from '../components/Footer';
import CTA from '../components/CTA';
---

<BaseLayout title="Veelgestelde Vragen - Epoxy Vloeren" description="Antwoorden op veelgestelde vragen over epoxy vloeren, prijzen, onderhoud en het aanvraagproces.">
  <div class="min-h-screen selection:bg-epoxy-accent selection:text-epoxy-black">
    <Navbar />
    <main class="pt-20">
      <FAQ />
      <CTA />
    </main>
    <Footer />
  </div>
</BaseLayout>