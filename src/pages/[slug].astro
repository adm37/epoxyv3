---
import BaseLayout from '../layouts/BaseLayout.astro';
import { citySlugs, getSlugSeo, keywordSlugs, serviceSlugs } from '../data/site';
import ServicePage from '../components/pages/ServicePage';
import CityLandingPage from '../components/pages/CityLandingPage';
import MetallicCityLandingPage from '../components/pages/MetallicCityLandingPage';
import FlakeCityLandingPage from '../components/pages/FlakeCityLandingPage';
import CoatingCityLandingPage from '../components/pages/CoatingCityLandingPage';
import KeywordLandingPage from '../components/pages/KeywordLandingPage';

export async function getStaticPaths() {
  const allSlugs = Array.from(new Set([...keywordSlugs, ...serviceSlugs, ...citySlugs]));

  return allSlugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

let componentType = 'keyword';
const { title, description, schemaType } = getSlugSeo(slug);

if (keywordSlugs.includes(slug)) {
  componentType = 'keyword';
} else if (slug === "epoxy-coating" || slug === "metallic-epoxy" || slug === "flake-epoxy") {
  componentType = 'service';
} else if (slug.startsWith("metallic-epoxy-vloer-")) {
  componentType = 'metallic-city';
} else if (slug.startsWith("flake-epoxy-vloer-")) {
  componentType = 'flake-city';
} else if (slug.startsWith("epoxy-coating-vloer-")) {
  componentType = 'coating-city';
} else if (slug.startsWith("epoxy-vloer-")) {
  componentType = 'city';
} else {
  return Astro.redirect('/');
}
---

<BaseLayout {title} {description} {schemaType}>
  {componentType === 'keyword' && <KeywordLandingPage slug={slug} />}
  {componentType === 'service' && <ServicePage slug={slug} />}
  {componentType === 'metallic-city' && <MetallicCityLandingPage slug={slug} />}
  {componentType === 'flake-city' && <FlakeCityLandingPage slug={slug} />}
  {componentType === 'coating-city' && <CoatingCityLandingPage slug={slug} />}
  {componentType === 'city' && <CityLandingPage slug={slug} />}
</BaseLayout>