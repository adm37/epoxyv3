---

<BaseLayout {title} {description}>
  {componentType === 'keyword' && <KeywordLandingPage slug={slug} client:load />}
  {componentType === 'service' && <ServicePage slug={slug} client:load />}
  {componentType === 'metallic-city' && <MetallicCityLandingPage slug={slug} client:load />}
  {componentType === 'flake-city' && <FlakeCityLandingPage slug={slug} client:load />}
  {componentType === 'coating-city' && <CoatingCityLandingPage slug={slug} client:load />}
  {componentType === 'city' && <CityLandingPage slug={slug} client:load />}
</BaseLayout>