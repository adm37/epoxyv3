} else if (slug === "epoxy-coating" || slug === "metallic-epoxy" || slug === "flake-epoxy") {
  componentType = 'service';
  title = `${slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())} - Epoxy Vloeren`;
} else if (slug.startsWith("metallic-epoxy-vloer-")) {
  componentType = 'metallic-city';
  title = `Metallic Epoxy Vloer ${slug.replace('metallic-epoxy-vloer-', '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())} - Epoxy Vloeren`;
} else if (slug.startsWith("flake-epoxy-vloer-")) {
  componentType = 'flake-city';
  title = `Flake Epoxy Vloer ${slug.replace('flake-epoxy-vloer-', '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())} - Epoxy Vloeren`;
} else if (slug.startsWith("epoxy-coating-vloer-")) {
  componentType = 'coating-city';
  title = `Epoxy Coating Vloer ${slug.replace('epoxy-coating-vloer-', '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())} - Epoxy Vloeren`;
