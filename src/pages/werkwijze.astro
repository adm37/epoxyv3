---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import DetailedProcess from '../components/DetailedProcess';
import Footer from '../components/Footer';
import CTA from '../components/CTA';
---

<BaseLayout title="Werkwijze: Van Offerte tot Oplevering | Klasse Epoxy" description="Ontdek hoe Klasse Epoxy uw epoxy vloer realiseert. Van gratis intake en offerte tot vakkundige installatie en oplevering. Transparant, stap voor stap.">
  <div class="min-h-screen selection:bg-epoxy-accent selection:text-epoxy-black">
    <Navbar />
    <main class="pt-20">
      <DetailedProcess />
      <CTA />
    </main>
    <Footer />
  </div>
</BaseLayout>